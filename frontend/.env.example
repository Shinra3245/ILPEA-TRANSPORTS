# ==========================================
# VARIABLES DE ENTORNO — FRONTEND
# Copiar este archivo como .env y completar
# los valores desde Bitwarden > ILPEA-Credenciales
# Todas las variables DEBEN llevar prefijo VITE_
# para ser accesibles desde el codigo Vue
# ==========================================

# ---- FIREBASE (Cliente web) ----
# Estas claves son publicas por diseño de Firebase,
# la seguridad real va en las reglas de Firestore y Auth
VITE_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ---- API ----
# URL base del backend. En desarrollo apunta al puerto local
VITE_API_BASE_URL=http://localhost:4000