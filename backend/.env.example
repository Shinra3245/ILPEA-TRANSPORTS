# Backend server settings
PORT=3000
AUTH_MODE=firebase

# Option A: Inline JSON (single line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: Relative path from backend/src/server.js
FIREBASE_KEY_PATH=../config/firebase-key.json

# Optional: enables OpenAI endpoints
OPENAI_API_KEY=your_openai_api_key_here

# Optional: SMTP config for employee welcome emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_password_de_aplicacion
MAIL_FROM_EMAIL=tu_correo@gmail.com
MAIL_FROM_NAME=ILPEA TRANSPORTS
